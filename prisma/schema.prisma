generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SchoolPaymentMethod {
  id            String   @id @default(uuid())
  schoolId      String
  methodName    String
  accountName   String
  accountNumber String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("school_payment_methods")
}

model School {
  id                    String                @id @default(uuid())
  name                  String
  domain                String                @unique
  email                 String
  phone                 String?
  address               String?
  primaryColor          String?               @default("#3B82F6")
  secondaryColor        String?               @default("#10B981")
  logo                  String?
  isActive              Boolean               @default(true)
  maxTeachers           Int                   @default(20)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  reportTemplateModel   String?
  idCardTemplateModel   String?
  reportTemplateFileUrl String?
  idCardTemplateFileUrl String?
  academicYears         AcademicYear[]
  announcements         Announcement[]
  assignments           Assignment[]
  attendance            Attendance[]
  books                 Book[]
  classes               Class[]
  departments           Department[]
  fileUploads           FileUpload[]
  gradeLevels           GradeLevel[]
  grades                Grade[]
  groups                Group[]
  guardians             Guardian[]
  houses                House[]
  lessonPlans           LessonPlan[]
  loans                 Loan[]
  messageTemplates      MessageTemplate[]
  messages              Message[]
  payments              Payment[]
  paymentMethods        SchoolPaymentMethod[]
  students              Student[]
  subjects              Subject[]
  supportMessages       SupportMessage[]
  surveys               Survey[]
  teachers              Teacher[]
  transportRoutes       TransportRoute[]
  users                 User[]

  @@map("schools")
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  firstName        String
  lastName         String
  role             UserRole
  schoolId         String?
  avatar           String?
  isActive         Boolean          @default(true)
  lastLogin        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  groupMembers     GroupMember[]
  guardian         Guardian?
  receivedMessages Message[]        @relation("ReceivedMessages")
  sentMessages     Message[]        @relation("SentMessages")
  notifications    Notification[]
  refreshTokens    RefreshToken[]
  student          Student?
  supportResponses SupportMessage[] @relation("SupportResponder")
  supportMessages  SupportMessage[]
  teacher          Teacher?
  school           School?          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([schoolId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Student {
  id               String                 @id @default(uuid())
  userId           String                 @unique
  schoolId         String
  studentNumber    String
  dateOfBirth      DateTime
  gender           String
  enrollmentDate   DateTime               @default(now())
  guardianName     String?
  guardianPhone    String?
  guardianEmail    String?
  address          String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  gradeLevelId     String?
  houseId          String?
  transportRouteId String?
  submissions      AssignmentSubmission[]
  attendance       Attendance[]
  classes          ClassStudent[]
  grades           Grade[]
  loans            Loan[]
  payments         Payment[]
  guardians        StudentGuardian[]
  gradeLevel       GradeLevel?            @relation(fields: [gradeLevelId], references: [id])
  house            House?                 @relation(fields: [houseId], references: [id])
  school           School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  transportRoute   TransportRoute?        @relation(fields: [transportRouteId], references: [id])
  user             User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, studentNumber])
  @@index([schoolId])
  @@index([userId])
  @@index([gradeLevelId])
  @@index([houseId])
  @@index([transportRouteId])
  @@map("students")
}

model Guardian {
  id                     String            @id @default(uuid())
  userId                 String            @unique
  schoolId               String
  phone                  String?
  occupation             String?
  workAddress            String?
  emergencyContact       String?
  preferredContactMethod String?           @default("email")
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  school                 School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  students               StudentGuardian[]

  @@index([schoolId])
  @@index([userId])
  @@map("guardians")
}

model StudentGuardian {
  id           String   @id @default(uuid())
  studentId    String
  guardianId   String
  relationship String
  isPrimary    Boolean  @default(false)
  canPickup    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  guardian     Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([studentId])
  @@index([guardianId])
  @@map("student_guardians")
}

model Teacher {
  id                String       @id @default(uuid())
  userId            String       @unique
  schoolId          String
  employeeNumber    String
  specialization    String?
  hireDate          DateTime     @default(now())
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  departmentId      String?
  assignments       Assignment[]
  classes           Class[]
  headOfDepartments Department[] @relation("DepartmentHead")
  grades            Grade[]
  lessonPlans       LessonPlan[]
  department        Department?  @relation(fields: [departmentId], references: [id])
  school            School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([schoolId, employeeNumber])
  @@index([schoolId])
  @@index([userId])
  @@index([departmentId])
  @@map("teachers")
}

model AcademicYear {
  id        String   @id @default(uuid())
  schoolId  String
  year      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes   Class[]
  terms     Term[]

  @@unique([schoolId, year])
  @@index([schoolId])
  @@index([isCurrent])
  @@map("academic_years")
}

model Term {
  id             String       @id @default(uuid())
  academicYearId String
  name           String
  startDate      DateTime
  endDate        DateTime
  isCurrent      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  classes        Class[]
  grades         Grade[]
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@index([academicYearId])
  @@index([isCurrent])
  @@map("terms")
}

model Department {
  id            String    @id @default(uuid())
  schoolId      String
  name          String
  code          String
  description   String?
  headTeacherId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  classes       Class[]
  headTeacher   Teacher?  @relation("DepartmentHead", fields: [headTeacherId], references: [id])
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subjects      Subject[]
  teachers      Teacher[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([headTeacherId])
  @@map("departments")
}

model GradeLevel {
  id        String    @id @default(uuid())
  schoolId  String
  name      String
  level     Int
  sequence  Int
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  classes   Class[]
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students  Student[]

  @@unique([schoolId, level])
  @@index([schoolId])
  @@index([level])
  @@map("grade_levels")
}

model Subject {
  id           String       @id @default(uuid())
  schoolId     String
  name         String
  code         String
  description  String?
  credits      Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  departmentId String?
  classes      Class[]
  lessonPlans  LessonPlan[]
  department   Department?  @relation(fields: [departmentId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([departmentId])
  @@map("subjects")
}

model Class {
  id              String         @id @default(uuid())
  schoolId        String
  teacherId       String
  subjectId       String
  name            String
  section         String?
  academicYear    String
  semester        String?
  schedule        String?
  room            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  academicYearId  String
  departmentId    String?
  gradeLevelId    String?
  maxStudents     Int?           @default(40)
  termId          String?
  assignments     Assignment[]
  attendance      Attendance[]
  students        ClassStudent[]
  academicYearRef AcademicYear   @relation(fields: [academicYearId], references: [id])
  department      Department?    @relation(fields: [departmentId], references: [id])
  gradeLevel      GradeLevel?    @relation(fields: [gradeLevelId], references: [id])
  school          School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject         Subject        @relation(fields: [subjectId], references: [id])
  teacher         Teacher        @relation(fields: [teacherId], references: [id])
  term            Term?          @relation(fields: [termId], references: [id])
  lessonPlans     LessonPlan[]

  @@index([schoolId])
  @@index([teacherId])
  @@index([academicYearId])
  @@index([termId])
  @@index([gradeLevelId])
  @@index([departmentId])
  @@map("classes")
}

model ClassStudent {
  id         String   @id @default(uuid())
  classId    String
  studentId  String
  enrolledAt DateTime @default(now())
  class      Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId])
  @@index([classId])
  @@index([studentId])
  @@map("class_students")
}

model Assignment {
  id          String                 @id @default(uuid())
  schoolId    String
  classId     String
  teacherId   String
  title       String
  description String?
  dueDate     DateTime
  maxPoints   Int                    @default(100)
  attachments String?
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  submissions AssignmentSubmission[]
  class       Class                  @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     Teacher                @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([classId])
  @@map("assignments")
}

model AssignmentSubmission {
  id           String           @id @default(uuid())
  assignmentId String
  studentId    String
  submittedAt  DateTime         @default(now())
  content      String?
  attachments  String?
  status       AssignmentStatus @default(PENDING)
  score        Int?
  feedback     String?
  gradedAt     DateTime?
  assignment   Assignment       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
  @@map("assignment_submissions")
}

model Grade {
  id          String   @id @default(uuid())
  schoolId    String
  studentId   String
  teacherId   String
  subjectCode String
  term        String
  score       Float
  letterGrade String?
  comments    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  termId      String?
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher     Teacher  @relation(fields: [teacherId], references: [id])
  termRef     Term?    @relation(fields: [termId], references: [id])

  @@index([schoolId])
  @@index([studentId])
  @@index([termId])
  @@map("grades")
}

model Attendance {
  id        String           @id @default(uuid())
  schoolId  String
  classId   String
  studentId String
  date      DateTime
  status    AttendanceStatus
  remarks   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  class     Class            @relation(fields: [classId], references: [id], onDelete: Cascade)
  school    School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([classId, studentId, date])
  @@index([schoolId])
  @@index([studentId])
  @@map("attendance")
}

model Book {
  id              String   @id @default(uuid())
  schoolId        String
  title           String
  author          String
  isbn            String?
  category        String?
  totalCopies     Int      @default(1)
  availableCopies Int      @default(1)
  publisher       String?
  publishedYear   Int?
  description     String?
  coverImage      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  loans           Loan[]

  @@index([schoolId])
  @@index([isbn])
  @@map("books")
}

model Loan {
  id         String     @id @default(uuid())
  schoolId   String
  bookId     String
  studentId  String
  loanDate   DateTime   @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     LoanStatus @default(ACTIVE)
  fine       Float?     @default(0)
  remarks    String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  book       Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  school     School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@index([bookId])
  @@map("loans")
}

model Message {
  id         String    @id @default(uuid())
  schoolId   String
  senderId   String
  receiverId String
  subject    String?
  content    String
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  school     School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  sender     User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

model SupportMessage {
  id          String          @id @default(uuid())
  schoolId    String?
  userId      String
  subject     String
  message     String
  category    SupportCategory @default(GENERAL)
  priority    SupportPriority @default(MEDIUM)
  status      SupportStatus   @default(PENDING)
  response    String?
  isRead      Boolean         @default(false)
  respondedAt DateTime?
  respondedBy String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  responder   User?           @relation("SupportResponder", fields: [respondedBy], references: [id])
  school      School?         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("support_messages")
}

model Announcement {
  id          String    @id @default(uuid())
  schoolId    String
  title       String
  content     String
  targetRole  UserRole?
  isActive    Boolean   @default(true)
  publishedAt DateTime  @default(now())
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("announcements")
}

model Payment {
  id            String        @id @default(uuid())
  schoolId      String
  studentId     String
  amount        Float
  description   String
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidDate      DateTime?
  paymentMethod String?
  transactionId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  school        School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([studentId])
  @@map("payments")
}

model House {
  id          String    @id @default(uuid())
  schoolId    String
  name        String
  code        String?
  color       String?
  points      Int       @default(0)
  description String?
  motto       String?
  captainId   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students    Student[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("houses")
}

model TransportRoute {
  id          String    @id @default(uuid())
  schoolId    String
  routeName   String
  routeNumber String?
  busNumber   String?
  driverName  String?
  driverPhone String?
  capacity    Int       @default(50)
  stops       Json?
  pickupTime  String?
  dropoffTime String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  students    Student[]
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, routeNumber])
  @@index([schoolId])
  @@map("transport_routes")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  category  String   @default("system")
  isRead    Boolean  @default(false)
  actionUrl String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model SystemHealthSettings {
  id            Int      @id @default(1)
  autoRefresh   Json     @default("{\"enabled\": false, \"interval\": 30000}")
  alerts        Json     @default("{\"sound\": true, \"enabled\": true, \"thresholds\": {\"cpu\": 80, \"memory\": 85, \"storage\": 90, \"database\": 500, \"errorRate\": 5}}")
  display       Json     @default("{\"timeframe\": \"24h\", \"showCharts\": true, \"chartPoints\": 20, \"autoAcknowledgeAlerts\": false}")
  notifications Json     @default("{\"email\": false, \"browser\": true, \"webhook\": false, \"webhookUrl\": \"\"}")
  monitoring    Json     @default("{\"retentionDays\": 30, \"detailedLogging\": false, \"performanceMode\": \"balanced\"}")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("system_health_settings")
}

model Group {
  id          String         @id @default(uuid())
  schoolId    String
  name        String
  description String?
  type        GroupType      @default(CUSTOM)
  privacy     GroupPrivacy   @default(PRIVATE)
  createdBy   String
  avatar      String?
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  discussions Discussion[]
  events      Event[]
  members     GroupMember[]
  messages    GroupMessage[]
  school      School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([type])
  @@map("groups")
}

model GroupMember {
  id       String   @id @default(uuid())
  groupId  String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  isActive Boolean  @default(true)
  group    Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@map("group_members")
}

model GroupMessage {
  id        String   @id @default(uuid())
  groupId   String
  senderId  String
  content   String
  isRead    Boolean  @default(false)
  readCount Int      @default(0)
  fileUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([senderId])
  @@index([createdAt])
  @@map("group_messages")
}

model Discussion {
  id        String   @id @default(uuid())
  groupId   String
  title     String
  content   String
  createdBy String
  isPinned  Boolean  @default(false)
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  replies   Reply[]

  @@index([groupId])
  @@index([createdAt])
  @@map("discussions")
}

model Reply {
  id            String     @id @default(uuid())
  discussionId  String
  createdBy     String
  content       String
  parentReplyId String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  discussion    Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  parentReply   Reply?     @relation("ReplyReplies", fields: [parentReplyId], references: [id])
  childReplies  Reply[]    @relation("ReplyReplies")

  @@index([discussionId])
  @@index([createdBy])
  @@map("replies")
}

model FileUpload {
  id         String   @id @default(uuid())
  schoolId   String
  uploadedBy String
  fileName   String
  fileType   String
  fileSize   Int
  fileUrl    String
  groupId    String?
  messageId  String?
  category   String   @default("general")
  isPublic   Boolean  @default(false)
  createdAt  DateTime @default(now())
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([uploadedBy])
  @@index([groupId])
  @@map("file_uploads")
}

model Event {
  id            String              @id @default(uuid())
  groupId       String
  schoolId      String
  title         String
  description   String?
  startDate     DateTime
  endDate       DateTime?
  location      String?
  createdBy     String
  isAllDay      Boolean             @default(false)
  eventType     String              @default("meeting")
  banner        String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  notifications EventNotification[]
  rsvps         EventRSVP[]
  group         Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([startDate])
  @@map("events")
}

model EventRSVP {
  id          String    @id @default(uuid())
  eventId     String
  userId      String
  response    String    @default("pending")
  respondedAt DateTime?
  createdAt   DateTime  @default(now())
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_rsvps")
}

model EventNotification {
  id               String   @id @default(uuid())
  eventId          String
  userId           String
  notificationType String   @default("reminder")
  sentAt           DateTime @default(now())
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@map("event_notifications")
}

model MessageTemplate {
  id          String   @id @default(uuid())
  schoolId    String
  createdBy   String
  name        String
  description String?
  subject     String?
  content     String
  category    String   @default("general")
  variables   Json?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("message_templates")
}

model Survey {
  id          String           @id @default(uuid())
  groupId     String?
  schoolId    String
  createdBy   String
  title       String
  description String?
  isAnonymous Boolean          @default(false)
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  questions   SurveyQuestion[]
  school      School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([groupId])
  @@map("surveys")
}

model SurveyQuestion {
  id        String           @id @default(uuid())
  surveyId  String
  question  String
  type      String           @default("text")
  options   Json?
  createdAt DateTime         @default(now())
  survey    Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  responses SurveyResponse[]

  @@index([surveyId])
  @@map("survey_questions")
}

model SurveyResponse {
  id          String         @id @default(uuid())
  questionId  String
  responderId String
  response    String
  createdAt   DateTime       @default(now())
  question    SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
  @@map("survey_responses")
}

model LessonPlan {
  id         String           @id @default(uuid())
  schoolId   String
  teacherId  String
  classId    String?
  subjectId  String?
  title      String
  topic      String?
  date       DateTime
  duration   Int
  objectives Json
  materials  Json?
  activities Json
  assessment String?
  homework   String?
  notes      String?
  status     LessonPlanStatus @default(DRAFT)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  class      Class?           @relation(fields: [classId], references: [id])
  school     School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  subject    Subject?         @relation(fields: [subjectId], references: [id])
  teacher    Teacher          @relation(fields: [teacherId], references: [id])

  @@index([schoolId])
  @@index([teacherId])
  @@index([classId])
  @@index([date])
  @@index([status])
  @@map("lesson_plans")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  schoolId   String?
  action     String
  resource   String
  resourceId String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([schoolId])
  @@index([createdAt])
  @@map("audit_logs")
}

